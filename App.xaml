<Application x:Class="EveMultiPreview.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Dark Theme Color System -->
        <Color x:Key="BgDark">#FF1A1A2E</Color>
        <Color x:Key="BgPanel">#FF252540</Color>
        <Color x:Key="Accent">#FF00AAFF</Color>
        <Color x:Key="Accent2">#FF7B68EE</Color>
        <Color x:Key="TextPrimary">#FFFFFFFF</Color>
        <Color x:Key="TextSecondary">#FF888888</Color>
        <Color x:Key="BorderColor">#FF3A3A50</Color>

        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
        <SolidColorBrush x:Key="BgBaseBrush" Color="#FF1E1E30"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    </Application.Resources>
</Application>
