<Window x:Class="EveMultiPreview.Views.CopyLayoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copy Thumbnail Layout"
        Width="360" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1a1a2e">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#e0e6f0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF16a085"/>
    </Window.Resources>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Copy from -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Copy from:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
        <ComboBox x:Name="CmbFrom" Grid.Row="0" Grid.Column="1" Height="28" Margin="0,0,0,12"
                  FontSize="12"/>

        <!-- Copy to -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Copy to:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
        <ComboBox x:Name="CmbTo" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,0,0,12"
                  FontSize="12"/>

        <!-- Copy button -->
        <Button Grid.Row="2" Grid.ColumnSpan="2" Content="💾  Copy Layout" 
                Click="OnCopy" Height="36" FontSize="14" FontWeight="SemiBold"
                Background="{StaticResource AccentBrush}" Foreground="White"
                BorderThickness="0" Cursor="Hand" VerticalAlignment="Bottom"
                Margin="0,8,0,0"/>
    </Grid>
</Window>
