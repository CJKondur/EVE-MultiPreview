<Window x:Class="EveMultiPreview.Views.CopyLayoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.Copy.Title}"
        Width="420" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1a1a2e">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#e0e6f0"/>
        <SolidColorBrush x:Key="DimBrush" Color="#9aa3b2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF16a085"/>
    </Window.Resources>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Copy from -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource L.Copy.From}" VerticalAlignment="Center"
                   Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
        <ComboBox x:Name="CmbFrom" Grid.Row="0" Grid.Column="1" Height="28" Margin="0,0,0,12"
                  FontSize="12"/>

        <!-- Copy to -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource L.Copy.To}" VerticalAlignment="Center"
                   Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
        <ComboBox x:Name="CmbTo" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,0,0,12"
                  FontSize="12"/>

        <!-- What to copy -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource L.Copy.What}" VerticalAlignment="Top" Margin="0,4,0,0"
                   Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
            <RadioButton x:Name="RdoLayoutOnly" GroupName="What" IsChecked="True"
                         Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,2">
                <TextBlock Text="{DynamicResource L.Copy.LayoutOnly}" Foreground="{StaticResource TextBrush}"/>
            </RadioButton>
            <RadioButton x:Name="RdoFullProfile" GroupName="What"
                         Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,6,0,2">
                <StackPanel>
                    <TextBlock Text="{DynamicResource L.Copy.EntireProfile}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{DynamicResource L.Copy.EntireNote}"
                               Foreground="{StaticResource DimBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <!-- Copy button -->
        <Button Grid.Row="3" Grid.ColumnSpan="2" Content="{DynamicResource L.Copy.CopyBtn}"
                Click="OnCopy" Height="36" FontSize="14" FontWeight="SemiBold"
                Background="{StaticResource AccentBrush}" Foreground="White"
                BorderThickness="0" Cursor="Hand" VerticalAlignment="Bottom"
                Margin="0,8,0,0"/>
    </Grid>
</Window>
