<Window x:Class="EveMultiPreview.Views.CharacterStatEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stat Overrides"
        Width="620" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FF1a1a2e">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#e0e6f0"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8a95aa"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF16a085"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FF2f3b52"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,2,16,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16,14">
        <TextBlock x:Name="TxtHeader" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="Each row is a single metric. ☐ force OFF · ☑ force ON · ▣ inherit global. Use the category buttons to bulk-set all metrics in that category."
                   TextWrapping="Wrap" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>

        <!-- DPS -->
        <GroupBox Header="⚔ DPS">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="All On" Click="OnCategoryAllOn" Tag="Dps" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="All Off" Click="OnCategoryAllOff" Tag="Dps" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Inherit" Click="OnCategoryInherit" Tag="Dps" Padding="8,2"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                </StackPanel>
                <WrapPanel>
                    <CheckBox x:Name="CbDpsOut" IsThreeState="True" Content="Out · Dmg/s Out"       MinWidth="170"/>
                    <CheckBox x:Name="CbDpsIn"  IsThreeState="True" Content="In · Dmg/s In"          MinWidth="170"/>
                    <CheckBox x:Name="CbTdi"    IsThreeState="True" Content="TDI · Total Dmg In"     MinWidth="170"/>
                    <CheckBox x:Name="CbTdo"    IsThreeState="True" Content="TDO · Total Dmg Out"    MinWidth="170"/>
                </WrapPanel>
                <CheckBox x:Name="CbIncludeNpc" IsThreeState="True" Content="Include NPC damage in DPS" Margin="0,6,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Logi -->
        <GroupBox Header="🛡 Logi">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="All On" Click="OnCategoryAllOn" Tag="Logi" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="All Off" Click="OnCategoryAllOff" Tag="Logi" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Inherit" Click="OnCategoryInherit" Tag="Logi" Padding="8,2"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                </StackPanel>
                <WrapPanel>
                    <CheckBox x:Name="CbArps" IsThreeState="True" Content="ARPS · Armor Rep/s"          MinWidth="200"/>
                    <CheckBox x:Name="CbSrps" IsThreeState="True" Content="SRPS · Shield Rep/s"         MinWidth="200"/>
                    <CheckBox x:Name="CbCtps" IsThreeState="True" Content="CTPS · Cap Transf/s"         MinWidth="200"/>
                    <CheckBox x:Name="CbTaro" IsThreeState="True" Content="TARO · Total Armor Rep Out"  MinWidth="200"/>
                    <CheckBox x:Name="CbTari" IsThreeState="True" Content="TARI · Total Armor Rep In"   MinWidth="200"/>
                    <CheckBox x:Name="CbTsro" IsThreeState="True" Content="TSRO · Total Shield Rep Out" MinWidth="200"/>
                    <CheckBox x:Name="CbTsri" IsThreeState="True" Content="TSRI · Total Shield Rep In"  MinWidth="200"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Mining -->
        <GroupBox Header="⛏ Mining">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="All On" Click="OnCategoryAllOn" Tag="Mine" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="All Off" Click="OnCategoryAllOff" Tag="Mine" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Inherit" Click="OnCategoryInherit" Tag="Mine" Padding="8,2"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                </StackPanel>
                <WrapPanel>
                    <CheckBox x:Name="CbOmpc" IsThreeState="True" Content="OMPC · Ore Mined/Cycle"  MinWidth="200"/>
                    <CheckBox x:Name="CbOmph" IsThreeState="True" Content="OMPH · Ore Mined/Hour"   MinWidth="200"/>
                    <CheckBox x:Name="CbGmpc" IsThreeState="True" Content="GMPC · Gas Mined/Cycle"  MinWidth="200"/>
                    <CheckBox x:Name="CbGmph" IsThreeState="True" Content="GMPH · Gas Mined/Hour"   MinWidth="200"/>
                    <CheckBox x:Name="CbImph" IsThreeState="True" Content="IMPH · Ice Mined/Hour"   MinWidth="200"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Ratting -->
        <GroupBox Header="💰 Ratting">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="All On" Click="OnCategoryAllOn" Tag="Rat" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="All Off" Click="OnCategoryAllOff" Tag="Rat" Padding="8,2" Margin="0,0,6,0"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Inherit" Click="OnCategoryInherit" Tag="Rat" Padding="8,2"
                            Background="#2a3347" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                </StackPanel>
                <WrapPanel>
                    <CheckBox x:Name="CbTipt" IsThreeState="True" Content="TIPT · Total ISK/Tick"    MinWidth="200"/>
                    <CheckBox x:Name="CbTiph" IsThreeState="True" Content="TIPH · Total ISK/Hour"    MinWidth="200"/>
                    <CheckBox x:Name="CbTips" IsThreeState="True" Content="TIPS · Total ISK/Session" MinWidth="200"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Button row -->
        <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="BtnResetAll" Content="Reset all to Inherit"
                    Click="OnResetAll" Padding="12,6" HorizontalAlignment="Left"
                    Background="#2a3347" Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
            <Button Grid.Column="1" Content="Cancel" Click="OnCancel" IsCancel="True"
                    Padding="16,6" Margin="0,0,8,0"
                    Background="#2a3347" Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
            <Button Grid.Column="2" Content="Save" Click="OnSave" IsDefault="True"
                    Padding="20,6" FontWeight="SemiBold"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </StackPanel>
</Window>
