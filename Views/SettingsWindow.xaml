<Window x:Class="EveMultiPreview.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.SettingsTitle}"
        Width="1100" Height="850"
        MinWidth="620" MinHeight="500"
        Background="{StaticResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ResizeMode="CanResize">

    <!-- Ctrl+F focuses the settings search box (ApplicationCommands.Find's default gesture). -->
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Find" Executed="OnFindSettings"/>
    </Window.CommandBindings>

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <!-- Dark ComboBox: WPF default template ignores Background/Foreground, so we must use a custom ControlTemplate -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="{StaticResource BgPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="2"/>
                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="White"/>
            </Grid>
        </ControlTemplate>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <!-- WPF only honours IsEditable="True" if the template contains a TextBox
                                 named PART_EditableTextBox. Without it the box was uneditable, so a
                                 Layout Preset could never be named — and with no presets saved yet the
                                 dropdown was empty too, leaving no way to create the first one (#88). -->
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}"
                                     Visibility="Collapsed" Focusable="True"
                                     Background="Transparent" Foreground="White" CaretBrush="White"
                                     BorderThickness="0" Padding="0"
                                     Margin="6,3,23,3" VerticalAlignment="Center"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" Focusable="False" AllowsTransparency="True" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}" SnapsToDevicePixels="True">
                                    <Border Background="{StaticResource BgPanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="2"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3a3a5e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <!-- Sidebar button style with active highlight -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Small icon button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#e0e0e0" BorderBrush="#aaaaaa" BorderThickness="1" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#f0f0f0"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#cccccc"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" MinWidth="120" MaxWidth="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="WikiColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Profile Bar ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="5" Background="{StaticResource BgPanelBrush}"
                Padding="12,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <!-- Clocks — right side -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{DynamicResource L.Top.Local}" Foreground="#888888" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBlock x:Name="TxtClockLocal" Text="" Foreground="White" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{DynamicResource L.Top.Eve}" Foreground="#888888" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBlock x:Name="TxtClockEve" Text="" Foreground="White" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Profile controls — left side -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource L.Eve.ProfileLabel}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbProfiles" Width="180" SelectionChanged="OnProfileChanged"
                              Background="{StaticResource BgPanelBrush}" Foreground="White" Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource L.Common.New}" Padding="10,3" Click="OnCreateProfile" Background="#e0e0e0"
                            Foreground="#1a1a2e" BorderBrush="#cccccc"
                            Margin="0,0,4,0"/>
                    <Button Content="{DynamicResource L.Common.DeleteWord}" Padding="10,3" Click="OnDeleteProfile" Background="#e0e0e0"
                            Foreground="#993333" BorderBrush="#cccccc" Margin="0,0,12,0"/>
                    <Button Content="{DynamicResource L.Top.Apply}" Padding="10,3" Click="OnApplySettings"
                            Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                            FontWeight="SemiBold" Margin="0,0,4,0"/>
                    <Button Content="{DynamicResource L.Top.CopyProfile}" Padding="10,3" Click="OnCopyLayout"
                            Background="#e0e0e0" Foreground="#1a1a2e"
                            BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.CopyProfile}"
                            Margin="0,0,4,0"/>
                    <Button Content="{DynamicResource L.Top.Backup}" Padding="10,3" Click="OnBackupConfig"
                            Background="#e0e0e0" Foreground="#1a1a2e"
                            BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.Backup}"
                            Margin="0,0,4,0"/>
                    <Button Content="{DynamicResource L.Top.ResetPositions}" Padding="10,3" Click="OnResetThumbnailPositions"
                            Background="#e0e0e0" Foreground="#1a1a2e"
                            BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.ResetPositions}"
                            Margin="0,0,4,0"/>
                    <Button Content="{DynamicResource L.Top.Undo}" Padding="10,3" Click="OnUndoLayout"
                            Background="#e0e0e0" Foreground="#1a1a2e"
                            BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.Undo}"
                            Margin="0,0,4,0"/>
                    <Button Content="{DynamicResource L.Top.Redo}" Padding="10,3" Click="OnRedoLayout"
                            Background="#e0e0e0" Foreground="#1a1a2e"
                            BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.Redo}"
                            Margin="0,0,4,0"/>
                    <Button x:Name="BtnColorBlind" Content="{DynamicResource L.Top.CbMode}" Padding="10,3" Click="OnToggleColorBlind"
                            Background="#e0e0e0" Foreground="#1a1a2e"
                            BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.CbMode}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Sidebar ═══ -->
        <Border Grid.Row="1" Grid.Column="0" Background="#FF0f3460" Padding="4,8">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="2,0,2,8">
                    <TextBox x:Name="TxtSettingsSearch" Padding="6,4" TextChanged="OnSettingsSearchChanged" KeyDown="OnSettingsSearchKeyDown"
                             Background="{StaticResource BgPanelBrush}" Foreground="White" BorderBrush="{StaticResource BorderBrush}"
                             ToolTip="{DynamicResource L.Tt.SearchAll}"/>
                    <TextBlock x:Name="SearchPlaceholder" Text="{DynamicResource L.Top.SearchPlaceholder}" IsHitTestVisible="False"
                               Foreground="#80FFFFFF" Margin="9,0,0,0" VerticalAlignment="Center"/>
                    <Popup x:Name="SearchResultsPopup" PlacementTarget="{Binding ElementName=TxtSettingsSearch}" Placement="Bottom"
                           StaysOpen="False" MaxHeight="420">
                        <Border Background="{StaticResource BgPanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                            <ListBox x:Name="LstSearchResults" Width="252" MaxHeight="400" SelectionChanged="OnSearchResultSelected"
                                     Background="Transparent" Foreground="White" BorderThickness="0"/>
                        </Border>
                    </Popup>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SidebarPanel">
                    <Button x:Name="NavGeneral" Content="{DynamicResource L.Nav.General}" Click="NavButton_Click" Tag="General" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavThumbnails" Content="{DynamicResource L.Nav.Thumbnails}" Click="NavButton_Click" Tag="Thumbnails" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavLayout" Content="{DynamicResource L.Nav.Layout}" Click="NavButton_Click" Tag="Layout" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavHotkeys" Content="{DynamicResource L.Nav.Hotkeys}" Click="NavButton_Click" Tag="Hotkeys" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavColors" Content="{DynamicResource L.Nav.Colors}" Click="NavButton_Click" Tag="Colors" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavGroups" Content="{DynamicResource L.Nav.Groups}" Click="NavButton_Click" Tag="Groups" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavAlerts" Content="{DynamicResource L.Nav.Alerts}" Click="NavButton_Click" Tag="Alerts" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavSounds" Content="{DynamicResource L.Nav.Sounds}" Click="NavButton_Click" Tag="Sounds" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavVisibility" Content="{DynamicResource L.Nav.Visibility}" Click="NavButton_Click" Tag="Visibility" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavClient" Content="{DynamicResource L.Nav.Client}" Click="NavButton_Click" Tag="Client" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavFPS" Content="{DynamicResource L.Nav.FPS}" Click="NavButton_Click" Tag="FPSLimiter" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavPerformance" Content="{DynamicResource L.Nav.Performance}" Click="NavButton_Click" Tag="Performance" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavStats" Content="{DynamicResource L.Nav.Stats}" Click="NavButton_Click" Tag="StatsOverlay" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavManager" Content="{DynamicResource L.Nav.Manager}" Click="NavButton_Click" Tag="EVEManager" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavCrop" Content="{DynamicResource L.Nav.Crop}" Click="NavButton_Click" Tag="Crop" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavAbout" Content="{DynamicResource L.Nav.About}" Click="NavButton_Click" Tag="About" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="NavDebug" Content="{DynamicResource L.Nav.Debug}" Click="NavButton_Click" Tag="Debug" Style="{StaticResource NavBtn}"/>
                </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ Left Splitter ═══ -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="#FF1a1a3e" Cursor="SizeWE"/>

        <!-- ═══ Content ═══ -->
        <ScrollViewer Grid.Row="1" Grid.Column="2" Padding="16" VerticalScrollBarVisibility="Auto">
            <Grid>

                <!-- ══ 1. GENERAL ══ -->
                <StackPanel x:Name="PanelGeneral" Visibility="Visible">
                    <TextBlock Text="{DynamicResource L.General.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.General.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Language.Group}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="{DynamicResource L.Language.Label}" Width="100" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CmbLanguage" Width="200" SelectionChanged="OnLanguageChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Language.Note}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                    <CheckBox x:Name="ChkShowTimer" Content="{DynamicResource L.General.ShowTimer}" Margin="0,0,0,12" Checked="OnGeneralChanged" Unchecked="OnGeneralChanged"/>
                    <GroupBox Header="{DynamicResource L.General.HotkeyScope}">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{DynamicResource L.General.ActivationScope}"/>
                            <ComboBox x:Name="CmbHotkeyScope" Width="200" SelectionChanged="OnGeneralChanged"
                                      Background="{StaticResource BgPanelBrush}" Foreground="White">
                                <ComboBoxItem Content="{DynamicResource L.General.ScopeGlobal}" Tag="global"/>
                                <ComboBoxItem Content="{DynamicResource L.General.ScopeEveActive}" Tag="eve_active"/>
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.General.SystemHotkeys}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkSuspend}" Width="200"/>
                                <TextBox x:Name="TxtSuspendHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtSuspendHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkClickThrough}" Width="200"/>
                                <TextBox x:Name="TxtClickThroughHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtClickThroughHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkHideAll}" Width="200"/>
                                <TextBox x:Name="TxtHideShowHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtHideShowHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkHidePrimary}" Width="200"/>
                                <TextBox x:Name="TxtHidePrimaryHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtHidePrimaryHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkHidePip}" Width="200"/>
                                <TextBox x:Name="TxtHideSecondaryHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtHideSecondaryHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkHideCrops}" Width="200"/>
                                <TextBox x:Name="TxtHideCropsHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtHideCropsHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkProfileFwd}" Width="200"/>
                                <TextBox x:Name="TxtProfileCycleForward" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtProfileCycleForward" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkProfileBwd}" Width="200"/>
                                <TextBox x:Name="TxtProfileCycleBackward" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtProfileCycleBackward" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkQuickSwitch}" Width="200"/>
                                <TextBox x:Name="TxtQuickSwitchHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtQuickSwitchHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkUndo}" Width="200" ToolTip="{DynamicResource L.Tt.UndoHotkey}"/>
                                <TextBox x:Name="TxtUndoLayoutHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtUndoLayoutHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.HkRedo}" Width="200" ToolTip="{DynamicResource L.Tt.RedoHotkey}"/>
                                <TextBox x:Name="TxtRedoLayoutHotkey" Width="120" TextChanged="OnGeneralChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtRedoLayoutHotkey" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.General.Toggles}">
                        <StackPanel>
                            <CheckBox x:Name="ChkLockPositions" Content="{DynamicResource L.General.LockPositions}" Checked="OnGeneralChanged" Unchecked="OnGeneralChanged"/>
                            <CheckBox x:Name="ChkBroadcastHud" Content="{DynamicResource L.General.BroadcastHud}" ToolTip="{DynamicResource L.Tt.BroadcastHud}" Checked="OnGeneralChanged" Unchecked="OnGeneralChanged"/>
                            <CheckBox x:Name="ChkAutoSoloAudio" Content="{DynamicResource L.General.AutoSolo}" ToolTip="{DynamicResource L.Tt.AutoSolo}" Checked="OnGeneralChanged" Unchecked="OnGeneralChanged"/>
                            <CheckBox x:Name="ChkIndividualResize" Content="{DynamicResource L.General.IndividualResize}" Checked="OnGeneralChanged" Unchecked="OnGeneralChanged"/>
                            <TextBlock Text="{DynamicResource L.General.IndividualResizeNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,0"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.General.Minimize}">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{DynamicResource L.General.MinimizeDelay}"/>
                            <TextBox x:Name="TxtMinimizeDelay" Width="60" TextChanged="OnGeneralChanged"/>
                            <Label Content="{DynamicResource L.Common.Ms}"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.General.Cycling}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.General.CyclingNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.CycleDelay}" Width="120"/>
                                <TextBox x:Name="TxtCycleDelay" Width="60" TextChanged="OnGeneralChanged"/>
                                <Label Content="{DynamicResource L.Common.Ms}"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkCycleWhileHeld" Content="{DynamicResource L.General.CycleWhileHeld}"
                                      Checked="OnGeneralChanged" Unchecked="OnGeneralChanged" Margin="0,6,0,0"
                                      ToolTip="{DynamicResource L.Tt.CycleWhileHeld}"/>
                            <TextBlock Text="{DynamicResource L.General.CycleWhileHeldNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.General.UiSettings}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.General.UiSettingsNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.UiScale}" Width="120"/>
                                <Slider x:Name="SliderUiScale" Minimum="9" Maximum="20" Width="180"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="OnUiScaleChanged"/>
                                <TextBlock x:Name="TxtUiScaleValue" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.General.Startup}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.General.StartupNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.General.OnAppLaunch}" Width="140"/>
                                <ComboBox x:Name="CmbStartupSettings" Width="280" SelectionChanged="OnGeneralChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White">
                                    <ComboBoxItem Content="{DynamicResource L.General.StartupOff}" Tag="0"/>
                                    <ComboBoxItem Content="{DynamicResource L.General.StartupOpen}" Tag="1"/>
                                    <ComboBoxItem Content="{DynamicResource L.General.StartupMin}" Tag="2"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 2. THUMBNAILS ══ -->
                <StackPanel x:Name="PanelThumbnails" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Thumb.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Thumb.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Thumb.Basic}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.Opacity}" Width="180"/>
                                <Slider x:Name="SliderOpacity" Minimum="0" Maximum="100" Width="200" ValueChanged="OnOpacityChanged"/>
                                <TextBlock x:Name="TxtOpacityValue" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkOpacityOnHover" Content="{DynamicResource L.Thumb.OpacityHover}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.ExclusionBadge}" Width="180"/>
                                <ComboBox x:Name="CmbExclusionBadgePos" Width="140" SelectionChanged="OnThumbnailChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White">
                                    <ComboBoxItem Content="{DynamicResource L.Pos.TopLeft}" Tag="TopLeft"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.Top}" Tag="Top"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.TopRight}" Tag="TopRight"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.Left}" Tag="Left"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.Center}" Tag="Center"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.Right}" Tag="Right"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.BottomLeft}" Tag="BottomLeft"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.Bottom}" Tag="Bottom"/>
                                    <ComboBoxItem Content="{DynamicResource L.Pos.BottomRight}" Tag="BottomRight"/>
                                </ComboBox>
                                <TextBlock Text="{DynamicResource L.Thumb.ExclusionNote}" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkAlwaysOnTop" Content="{DynamicResource L.Thumb.AlwaysOnTop}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <CheckBox x:Name="ChkAboveClients" Content="{DynamicResource L.Thumb.AboveClients}" ToolTip="{DynamicResource L.Tt.AboveClients}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <CheckBox x:Name="ChkHideOnLostFocus" Content="{DynamicResource L.Thumb.HideAltTab}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <CheckBox x:Name="ChkHideActive" Content="{DynamicResource L.Thumb.HideActive}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <CheckBox x:Name="ChkShowSystem" Content="{DynamicResource L.Thumb.ShowSystem}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <CheckBox x:Name="ChkShowStats" Content="{DynamicResource L.Thumb.ShowStats}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                                <Label Content="{DynamicResource L.Common.Size}" Margin="12,0,0,0"/>
                                <TextBox x:Name="TxtStatsTextSize" Width="35" Text="9" TextChanged="OnThumbnailChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Thumb.TextOverlay}">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowName" Content="{DynamicResource L.Thumb.ShowTextOverlay}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.TextColor}" Width="140"/>
                                <TextBox x:Name="TxtTextColor" Width="100" TextChanged="OnThumbnailChanged"/>
                                <Border x:Name="PreviewTextColor" Width="22" Height="22" Margin="4,0,0,0" BorderBrush="Gray" BorderThickness="1"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtTextColor" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.TextSize}" Width="140"/>
                                <TextBox x:Name="TxtTextSize" Width="50" TextChanged="OnThumbnailChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.TextFont}" Width="140"/>
                                <TextBox x:Name="TxtTextFont" Width="150" TextChanged="OnThumbnailChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.TextMargins}" Width="140"/>
                                <TextBox x:Name="TxtTextMarginX" Width="50" TextChanged="OnThumbnailChanged"/>
                                <TextBlock Text=" × " VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtTextMarginY" Width="50" TextChanged="OnThumbnailChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Thumb.Borders}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.HighlightColor}" Width="160"/>
                                <TextBox x:Name="TxtActiveColor" Width="100" TextChanged="OnThumbnailChanged"/>
                                <Border x:Name="PreviewActiveColor" Width="22" Height="22" Margin="4,0,0,0" BorderBrush="Gray" BorderThickness="1"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtActiveColor" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.HighlightBorder}" Width="160"/>
                                <TextBox x:Name="TxtActiveBorderThickness" Width="50" TextChanged="OnThumbnailChanged"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkShowHighlightBorder" Content="{DynamicResource L.Thumb.ShowHighlightBorder}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <CheckBox x:Name="ChkShowAllBorders" Content="{DynamicResource L.Thumb.ShowAllBorders}" Checked="OnThumbnailChanged" Unchecked="OnThumbnailChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.InactiveBorder}" Width="160"/>
                                <TextBox x:Name="TxtFrameThickness" Width="50" TextChanged="OnThumbnailChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.InactiveBorderColor}" Width="160"/>
                                <TextBox x:Name="TxtInactiveColor" Width="100" TextChanged="OnThumbnailChanged"/>
                                <Border x:Name="PreviewInactiveColor" Width="22" Height="22" Margin="4,0,0,0" BorderBrush="Gray" BorderThickness="1"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtInactiveColor" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Thumb.BgColor}" Width="160"/>
                                <TextBox x:Name="TxtBackgroundColor" Width="100" TextChanged="OnThumbnailChanged"/>
                                <Border x:Name="PreviewBgColor" Width="22" Height="22" Margin="4,0,0,0" BorderBrush="Gray" BorderThickness="1"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtBackgroundColor" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Thumb.Annotations}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Thumb.AnnotationsNote}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <ListView x:Name="LstAnnotations" Height="120" Margin="0,0,0,4"
                                      Background="{StaticResource BgPanelBrush}" Foreground="White"
                                      SelectionMode="Single">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="180" DisplayMemberBinding="{Binding Character}"/>
                                        <GridViewColumn Header="{DynamicResource L.Common.Label}" Width="120" DisplayMemberBinding="{Binding Label}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource L.Common.Edit}" Padding="10,4" Click="OnEditAnnotation" Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource L.Common.Clear}" Padding="10,4" Click="OnClearAnnotation"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 3. LAYOUT ══ -->
                <StackPanel x:Name="PanelLayout" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Layout.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Layout.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Layout.DefaultLocation}">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{DynamicResource L.Common.X}"/><TextBox x:Name="TxtStartX" Width="60" TextChanged="OnLayoutChanged"/>
                            <Label Content="{DynamicResource L.Common.Y}" Margin="8,0,0,0"/><TextBox x:Name="TxtStartY" Width="60" TextChanged="OnLayoutChanged"/>
                            <Label Content="{DynamicResource L.Common.W}" Margin="8,0,0,0"/><TextBox x:Name="TxtThumbWidth" Width="60" TextChanged="OnLayoutChanged"/>
                            <Label Content="{DynamicResource L.Common.H}" Margin="8,0,0,0"/><TextBox x:Name="TxtThumbHeight" Width="60" TextChanged="OnLayoutChanged"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Layout.ActiveCharSizing}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Layout.ActiveCharNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <Label Content="{DynamicResource L.Layout.Character}"/>
                                <ComboBox x:Name="CmbActiveChars" Width="180" SelectionChanged="OnActiveCharSelected"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                                <Button Content="{DynamicResource L.Common.Refresh}" Click="OnRefreshActiveChars" Padding="5,2" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Label Content="{DynamicResource L.Common.W}"/><TextBox x:Name="TxtActiveCharW" Width="60"/>
                                <Label Content="{DynamicResource L.Common.H}" Margin="8,0,0,0"/><TextBox x:Name="TxtActiveCharH" Width="60"/>
                                <Button Content="{DynamicResource L.Layout.ApplySize}" Click="OnApplyActiveCharSize" Margin="12,0,0,0"
                                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Padding="10,3"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Layout.MinSize}">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{DynamicResource L.Common.W}"/><TextBox x:Name="TxtMinWidth" Width="60" TextChanged="OnLayoutChanged"/>
                            <Label Content="{DynamicResource L.Common.H}" Margin="8,0,0,0"/><TextBox x:Name="TxtMinHeight" Width="60" TextChanged="OnLayoutChanged"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Layout.Snapping}">
                        <StackPanel>
                            <CheckBox x:Name="ChkSnap" Content="{DynamicResource L.Layout.EnableSnap}" Checked="OnLayoutChanged" Unchecked="OnLayoutChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Label Content="{DynamicResource L.Layout.SnapDistance}"/>
                                <TextBox x:Name="TxtSnapDistance" Width="60" TextChanged="OnLayoutChanged"/>
                                <Label Content="{DynamicResource L.Common.Px}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Label Content="{DynamicResource L.Layout.EdgeGutter}" ToolTip="{DynamicResource L.Tt.EdgeGutter}"/>
                                <TextBox x:Name="TxtGutter" Width="60" TextChanged="OnLayoutChanged"
                                         ToolTip="{DynamicResource L.Tt.EdgeGutter}"/>
                                <Label Content="{DynamicResource L.Common.Px}"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkConfineMonitor" Content="{DynamicResource L.Layout.ConfineMonitor}" Margin="0,6,0,0"
                                      ToolTip="{DynamicResource L.Tt.ConfineMonitor}"
                                      Checked="OnLayoutChanged" Unchecked="OnLayoutChanged"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Layout.Presets}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Layout.PresetsNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="CmbLayoutPresets" Width="180" IsEditable="True" StaysOpenOnEdit="True"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"
                                          ToolTip="{DynamicResource L.Tt.PresetCombo}"/>
                                <Button Content="{DynamicResource L.Common.Save}" Click="OnSaveLayoutPreset" Margin="6,0,0,0" Padding="8,3"
                                        Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                                        ToolTip="{DynamicResource L.Tt.PresetSave}"/>
                                <Button Content="{DynamicResource L.Common.Apply}" Click="OnApplyLayoutPreset" Margin="4,0,0,0" Padding="8,3"
                                        Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"/>
                                <Button Content="{DynamicResource L.Common.Delete}" Click="OnDeleteLayoutPreset" Margin="4,0,0,0" Padding="8,3"
                                        Background="#e0e0e0" Foreground="#993333" BorderBrush="#cccccc"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{DynamicResource L.Layout.Remap}" Click="OnRemapLayoutPreset" Padding="8,3"
                                        Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                                        ToolTip="{DynamicResource L.Tt.PresetRemap}"/>
                                <Button Content="{DynamicResource L.Common.Export}" Click="OnExportLayoutPreset" Margin="4,0,0,0" Padding="8,3"
                                        Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                                        ToolTip="{DynamicResource L.Tt.PresetExport}"/>
                                <Button Content="{DynamicResource L.Common.Import}" Click="OnImportLayoutPreset" Margin="4,0,0,0" Padding="8,3"
                                        Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                                        ToolTip="{DynamicResource L.Tt.PresetImport}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Layout.HoverZoom}">
                        <StackPanel>
                            <CheckBox x:Name="ChkHoverZoom" Content="{DynamicResource L.Layout.ZoomOnHover}" Checked="OnLayoutChanged" Unchecked="OnLayoutChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Label Content="{DynamicResource L.Layout.ZoomScale}"/>
                                <TextBox x:Name="TxtHoverScale" Width="60" TextChanged="OnLayoutChanged"/>
                                <Label Content="{DynamicResource L.Common.Multiplier}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Layout.Monitor}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="{DynamicResource L.Layout.PreferredMonitor}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CmbPreferredMonitor" Width="200" SelectionChanged="OnLayoutChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                                <Button Content="{DynamicResource L.Layout.Identify}" Click="OnIdentifyMonitors" Padding="10,3" Margin="8,0,0,0"
                                        Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="{StaticResource BorderBrush}"
                                        VerticalAlignment="Center"
                                        ToolTip="{DynamicResource L.Tt.Identify}"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Layout.MonitorNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 4. CHAR HOTKEYS ══ -->
                <StackPanel x:Name="PanelHotkeys" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Hk.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Hk.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Hk.IndividualHeader}">
                        <StackPanel>
                            <ListView x:Name="LvHotkeys" Height="200"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" SelectionChanged="OnHotkeySelected">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="220" DisplayMemberBinding="{Binding Character}"/>
                                        <GridViewColumn Header="{DynamicResource L.Common.Hotkey}" Width="150" DisplayMemberBinding="{Binding Hotkey}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{DynamicResource L.Common.Add}" Padding="8,3" Click="OnHotkeyAdd" Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource L.Common.EditItem}" Padding="8,3" Click="OnHotkeyEdit" Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource L.Common.DeleteItem}" Padding="8,3" Click="OnHotkeyDelete"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Hk.AuditHeader}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Hk.AuditNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Button Content="{DynamicResource L.Hk.Refresh}" Click="OnRefreshHotkeyAudit" Padding="10,3" HorizontalAlignment="Left"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" Margin="0,0,0,8"/>
                            <StackPanel x:Name="HotkeyAuditRows"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 5. COLORS ══ -->
                <StackPanel x:Name="PanelColors" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Colors.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Colors.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Colors.Header}">
                        <StackPanel>
                            <CheckBox x:Name="ChkCustomColorsActive" Content="{DynamicResource L.Colors.Enable}"
                                      Checked="OnColorChanged" Unchecked="OnColorChanged"/>
                            <ListView x:Name="LvColors" Height="250" Margin="0,8,0,0"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" SelectionChanged="OnColorRowSelected">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="140" DisplayMemberBinding="{Binding Character}"/>
                                        <GridViewColumn Header="{DynamicResource L.Colors.ColActiveBorder}" Width="95" DisplayMemberBinding="{Binding ActiveBorder}"/>
                                        <GridViewColumn Header="{DynamicResource L.Colors.ColTextColor}" Width="95" DisplayMemberBinding="{Binding TextColor}"/>
                                        <GridViewColumn Header="{DynamicResource L.Colors.ColInactiveBorder}" Width="95" DisplayMemberBinding="{Binding InactiveBorder}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{DynamicResource L.Common.Add}" Padding="8,3" Click="OnColorAdd" Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource L.Common.EditItem}" Padding="8,3" Click="OnColorEdit" Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource L.Common.DeleteItem}" Padding="8,3" Click="OnColorDelete"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{DynamicResource L.Colors.Preview}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource L.Colors.Active}" FontSize="9" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Border x:Name="ColorPreviewActive" Width="24" Height="20" BorderBrush="Gray" BorderThickness="1" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource L.Colors.Text}" FontSize="9" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Border x:Name="ColorPreviewText" Width="24" Height="20" BorderBrush="Gray" BorderThickness="1" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource L.Colors.Inactive}" FontSize="9" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Border x:Name="ColorPreviewInactive" Width="24" Height="20" BorderBrush="Gray" BorderThickness="1"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 6. GROUPS ══ -->
                <StackPanel x:Name="PanelGroups" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Groups.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Groups.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Groups.Header}">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowGroupBorders" Content="{DynamicResource L.Groups.ShowBorders}" Checked="OnGroupBordersChanged" Unchecked="OnGroupBordersChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Label Content="{DynamicResource L.Groups.SelectGroup}"/>
                                <ComboBox x:Name="CmbGroupSelect" Width="200" SelectionChanged="OnGroupSelectChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Label Content="{DynamicResource L.Groups.GroupName}" Width="100"/>
                                <TextBox x:Name="TxtGroupName" Width="200"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Label Content="{DynamicResource L.Groups.BorderColor}" Width="100"/>
                                <TextBox x:Name="TxtGroupColor" Width="100" TextChanged="OnGroupDataChanged"/>
                                <Border x:Name="PreviewGroupColor" Width="22" Height="22" Margin="4,0,0,0" BorderBrush="Gray" BorderThickness="1"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtGroupColor" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Groups.CharsPerLine}" Margin="0,8,0,2"/>
                            <TextBox x:Name="TxtGroupChars" Height="120" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextChanged="OnGroupDataChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{DynamicResource L.Common.AddCharacter}" Padding="8,3" Click="OnGroupAddChar" Margin="0,0,8,0"/>
                                <Button Content="{DynamicResource L.Groups.SaveGroup}" Padding="8,3" Click="OnGroupSave" Margin="0,0,8,0"
                                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                                <Button Content="{DynamicResource L.Groups.DeleteGroup}" Padding="8,3" Click="OnGroupDelete"
                                        Foreground="#FF993333" BorderBrush="#FF993333"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Groups.CyclingHeader}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Groups.CyclingNote}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <ComboBox x:Name="CmbHotkeyGroup" Width="200" SelectionChanged="OnHotkeyGroupChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                                <Button Content="{DynamicResource L.Common.New}" Padding="8,3" Click="OnHotkeyGroupNew" Margin="4,0,0,0"/>
                                <Button Content="{DynamicResource L.Common.DeleteWord}" Padding="8,3" Click="OnHotkeyGroupDelete" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBox x:Name="TxtHotkeyGroupChars" Height="100" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     TextChanged="OnHotkeyGroupCharsChanged" IsEnabled="False"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Label Content="{DynamicResource L.Groups.Forward}"/>
                                <TextBox x:Name="TxtGroupFwd" Width="120" TextChanged="OnHotkeyGroupKeysChanged" IsEnabled="False"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtGroupFwd" Margin="4,0,0,0"/>
                                <Label Content="{DynamicResource L.Groups.Backward}" Margin="8,0,0,0"/>
                                <TextBox x:Name="TxtGroupBwd" Width="120" TextChanged="OnHotkeyGroupKeysChanged" IsEnabled="False"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtGroupBwd" Margin="4,0,0,0"/>
                            </StackPanel>
                            <Button Content="{DynamicResource L.Common.AddCharacter}" Padding="8,3" Click="OnHotkeyGroupAddChar" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 7. ALERTS ══ -->
                <StackPanel x:Name="PanelAlerts" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Alerts.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Alerts.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Alerts.LogMonitoring}">
                        <StackPanel>
                            <CheckBox x:Name="ChkChatLogMon" Content="{DynamicResource L.Alerts.EnableChatLog}" Checked="OnAlertChanged" Unchecked="OnAlertChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Alerts.ChatLogDir}" Width="100"/>
                                <TextBox x:Name="TxtChatLogDir" Width="250" TextChanged="OnAlertChanged"/>
                                <Button Content="📁" Style="{StaticResource IconBtn}" Click="OnBrowseChatLog" Margin="4,0,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkGameLogMon" Content="{DynamicResource L.Alerts.EnableGameLog}" Checked="OnAlertChanged" Unchecked="OnAlertChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Alerts.GameLogDir}" Width="100"/>
                                <TextBox x:Name="TxtGameLogDir" Width="250" TextChanged="OnAlertChanged"/>
                                <Button Content="📁" Style="{StaticResource IconBtn}" Click="OnBrowseGameLog" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Alerts.UnderFire}">
                        <StackPanel>
                            <CheckBox x:Name="ChkUnderFire" Content="{DynamicResource L.Alerts.UnderFirePulse}" Checked="OnAlertChanged" Unchecked="OnAlertChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Alerts.TimeoutSeconds}" Width="140"/>
                                <TextBox x:Name="TxtUnderFireTimeout" Width="50" TextChanged="OnAlertChanged"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Alerts.UnderFireNote}" Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="10.5"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Alerts.AlertEvents}">
                        <StackPanel>

                            <CheckBox x:Name="ChkPveMode" Content="{DynamicResource L.Alerts.PveMode}" Checked="OnAlertChanged" Unchecked="OnAlertChanged"/>
                            <TextBlock Text="{DynamicResource L.Alerts.PveModeNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Label Content="{DynamicResource L.Alerts.PulseOpacity}" Width="120" VerticalAlignment="Center"/>
                                <Slider x:Name="SliderAlertOpacity" Minimum="10" Maximum="100" Width="180"
                                        IsSnapToTickEnabled="True" TickFrequency="5"
                                        ValueChanged="OnAlertOpacityChanged"/>
                                <TextBlock x:Name="TxtAlertOpacityValue" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Alerts.PulseOpacityNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Label Content="{DynamicResource L.Alerts.BorderWidth}" Width="120" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtAlertBorderThickness" Width="50" TextChanged="OnAlertChanged"/>
                                <Label Content="{DynamicResource L.Common.Px}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Alerts.BorderWidthNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <CheckBox x:Name="ChkAlertBadgeOnThumbnails" Content="{DynamicResource L.Alerts.BadgeShow}" Checked="OnAlertChanged" Unchecked="OnAlertChanged"/>
                            <TextBlock Text="{DynamicResource L.Alerts.BadgeNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,8" TextWrapping="Wrap"/>
                            <!-- Per-event rows built in code-behind -->
                            <StackPanel x:Name="AlertEventRows"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Alerts.Severity}">
                        <StackPanel x:Name="SeverityRows"/>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Alerts.Hub}">
                        <StackPanel>
                            <CheckBox x:Name="ChkAlertHub" Content="{DynamicResource L.Alerts.HubShow}" Checked="OnManagerChanged" Unchecked="OnManagerChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Alerts.ToastDuration}" Width="120"/>
                                <TextBox x:Name="TxtToastDuration" Width="50" TextChanged="OnManagerChanged"/>
                                <Label Content="{DynamicResource L.Common.Seconds}"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkSuppressToastActive" Content="{DynamicResource L.Alerts.SuppressActive}" Checked="OnManagerChanged" Unchecked="OnManagerChanged" Margin="0,4,0,0"/>
                            <TextBlock Text="{DynamicResource L.Alerts.SuppressActiveNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,4" TextWrapping="Wrap"/>
                            <CheckBox x:Name="ChkAlertHubAutoHide" Content="{DynamicResource L.Alerts.AutoHide}" Checked="OnManagerChanged" Unchecked="OnManagerChanged" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="24,2,0,0">
                                <Label Content="{DynamicResource L.Alerts.HideAfter}" Width="96"/>
                                <TextBox x:Name="TxtAlertHubAutoHideSeconds" Width="50" TextChanged="OnManagerChanged"/>
                                <Label Content="{DynamicResource L.Alerts.HideAfterUnit}"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Alerts.AutoHideNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,2,0,4" TextWrapping="Wrap"/>
                            <Button Content="{DynamicResource L.Alerts.ResetHub}" Padding="8,3" Click="OnResetHubPosition" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Alerts.NotLoggedIn}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="{DynamicResource L.Common.Style}"/>
                                <ComboBox x:Name="CmbNotLoggedIn" Width="140" SelectionChanged="OnAlertChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White">
                                    <ComboBoxItem Content="{DynamicResource L.Alerts.NliNone}" Tag="none"/>
                                    <ComboBoxItem Content="{DynamicResource L.Alerts.NliText}" Tag="text"/>
                                    <ComboBoxItem Content="{DynamicResource L.Alerts.NliBorder}" Tag="border"/>
                                    <ComboBoxItem Content="{DynamicResource L.Alerts.NliDim}" Tag="dim"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Alerts.IndicatorColor}" Width="120"/>
                                <TextBox x:Name="TxtNotLoggedInColor" Width="100" TextChanged="OnAlertChanged"/>
                                <Border x:Name="PreviewNotLoggedIn" Width="22" Height="22" Margin="4,0,0,0" BorderBrush="Gray" BorderThickness="1"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtNotLoggedInColor" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 8. SOUNDS ══ -->
                <StackPanel x:Name="PanelSounds" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Sounds.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Sounds.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Sounds.Master}">
                        <StackPanel>
                            <CheckBox x:Name="ChkEnableSounds" Content="{DynamicResource L.Sounds.Enable}" Checked="OnSoundChanged" Unchecked="OnSoundChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Sounds.MasterVolume}" Width="120"/>
                                <TextBox x:Name="TxtMasterVolume" Width="50" TextChanged="OnSoundChanged"/>
                                <Label Content="{DynamicResource L.Sounds.Range0100}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Sounds.PerEvent}">
                        <!-- Built dynamically in code-behind -->
                        <StackPanel x:Name="SoundEventRows"/>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Sounds.PerClientVol}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Sounds.PerClientNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Button Content="{DynamicResource L.Common.RefreshBtn}" Click="OnRefreshClientVolumes" Padding="10,3" HorizontalAlignment="Left"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" Margin="0,0,0,8"/>
                            <StackPanel x:Name="ClientVolumeRows"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 9. VISIBILITY ══ -->
                <StackPanel x:Name="PanelVisibility" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Vis.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Vis.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Vis.Primary}">
                        <StackPanel>
                            <Button Content="{DynamicResource L.Common.RefreshBtn}" Click="OnRefreshVisibility" Padding="10,3" HorizontalAlignment="Left"
                                    Background="#e0e0e0" Foreground="#1a1a2e"
                                    BorderBrush="#cccccc" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource L.Vis.CheckToHide}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource L.Vis.Tip}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6"/>
                            <ListView x:Name="LvVisibility" Height="250"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="180" DisplayMemberBinding="{Binding Character}"/>
                                        <GridViewColumn Header="{DynamicResource L.Vis.ColHidden}" Width="60">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding Hidden, Mode=TwoWay}"
                                                              Checked="OnVisibilityRowToggled"
                                                              Unchecked="OnVisibilityRowToggled"
                                                              HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource L.Common.Label}" Width="150" DisplayMemberBinding="{Binding Label}"/>
                                        <GridViewColumn Header="" Width="70">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{DynamicResource L.Vis.EditBtn}" Padding="8,2" Click="OnEditVisibilityLabel"
                                                            ToolTip="{DynamicResource L.Tt.EditLabel}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Vis.Secondary}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Vis.SecondaryNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6"/>
                            <ListView x:Name="LvSecondaryThumbnails" Height="150"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" SelectionChanged="OnSecThumbSelected">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="180" DisplayMemberBinding="{Binding Character}"/>
                                        <GridViewColumn Header="{DynamicResource L.Common.Enabled}" Width="70" DisplayMemberBinding="{Binding Enabled}"/>
                                        <GridViewColumn Header="{DynamicResource L.Common.Opacity}" Width="70" DisplayMemberBinding="{Binding Opacity}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{DynamicResource L.Common.Add}" Padding="8,3" Click="OnSecThumbAdd" Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource L.Common.Remove}" Padding="8,3" Click="OnSecThumbRemove" Margin="0,0,16,0"/>
                                <Label Content="{DynamicResource L.Common.OpacityColon}"/>
                                <Slider x:Name="SliderSecOpacity" Minimum="20" Maximum="255" Width="120" ValueChanged="OnSecThumbOpacityChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 10. CLIENT ══ -->
                <StackPanel x:Name="PanelClient" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Client.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Client.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Client.CharSelectCycling}">
                        <StackPanel>
                            <CheckBox x:Name="ChkCharSelectCycle" Content="{DynamicResource L.Client.EnableCharSelect}" Checked="OnClientChanged" Unchecked="OnClientChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Label Content="{DynamicResource L.Client.ForwardHotkey}" Width="140"/>
                                <TextBox x:Name="TxtCharSelectFwd" Width="120" TextChanged="OnClientChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtCharSelectFwd" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Label Content="{DynamicResource L.Client.BackwardHotkey}" Width="140"/>
                                <TextBox x:Name="TxtCharSelectBwd" Width="120" TextChanged="OnClientChanged" GotFocus="OnHotkeyFieldGotFocus" LostFocus="OnHotkeyFieldLostFocus"/>
                                <Button Content="⌨" Style="{StaticResource IconBtn}" Click="OnCaptureHotkey" Tag="TxtCharSelectBwd" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Client.WindowMgmt}">
                        <StackPanel>
                            <CheckBox x:Name="ChkMinimizeInactive" Content="{DynamicResource L.Client.MinimizeInactive}"
                                      Checked="OnClientChanged" Unchecked="OnClientChanged"/>
                            <CheckBox x:Name="ChkAlwaysMaximize" Content="{DynamicResource L.Client.AlwaysMaximize}"
                                      Checked="OnClientChanged" Unchecked="OnClientChanged"/>
                            <CheckBox x:Name="ChkTrackClientPositions" Content="{DynamicResource L.Client.TrackPositions}"
                                      Checked="OnClientChanged" Unchecked="OnClientChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Label Content="{DynamicResource L.Client.SpawnPosition}" Width="140" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CmbClientPosition" Width="200" SelectionChanged="OnClientPositionModeChanged">
                                    <ComboBoxItem Content="{DynamicResource L.Client.SpawnOff}"/>
                                    <ComboBoxItem Content="{DynamicResource L.Client.SpawnCenter}"/>
                                    <ComboBoxItem Content="{DynamicResource L.Client.SpawnCustom}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="PanelClientPositionXY" Orientation="Horizontal" Margin="140,4,0,0" Visibility="Collapsed">
                                <Label Content="{DynamicResource L.Common.XCap}" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtClientPositionX" Width="70" TextChanged="OnClientChanged"/>
                                <Label Content="{DynamicResource L.Common.YCap}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtClientPositionY" Width="70" TextChanged="OnClientChanged"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Client.SpawnNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Client.DontMinimize}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Client.DontMinNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,4"/>
                            <ListView x:Name="LvDontMinimize" Height="120"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.CharacterName}" Width="220" DisplayMemberBinding="{Binding CharacterName}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{DynamicResource L.Common.Add}" Padding="8,3" Click="OnDontMinAdd" Margin="0,0,4,0"/>
                                <Button Content="{DynamicResource L.Common.DeleteItem}" Padding="8,3" Click="OnDontMinDelete"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ NEW: PERFORMANCE ══ -->
                <StackPanel x:Name="PanelPerformance" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Perf.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Perf.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Perf.GlobalSettings}">
                        <StackPanel>
                            <CheckBox x:Name="ChkManageAffinity" Content="{DynamicResource L.Perf.ManageAffinity}" Checked="OnPerformanceChanged" Unchecked="OnPerformanceChanged"/>
                            <TextBlock Text="{DynamicResource L.Perf.ManageAffinityNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,8"/>
                            <CheckBox x:Name="ChkAutoBalanceCores" Content="{DynamicResource L.Perf.AutoBalance}" Checked="OnPerformanceChanged" Unchecked="OnPerformanceChanged"/>
                            <TextBlock Text="{DynamicResource L.Perf.AutoBalanceNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,4"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Perf.GpuOpt}">
                        <StackPanel>
                            <Button x:Name="BtnLowGpuPreset" Content="{DynamicResource L.Perf.LowGpuBtn}"
                                    Click="OnLowGpuPreset" Padding="10,6" Margin="0,0,0,4" HorizontalAlignment="Left"/>
                            <TextBlock Text="{DynamicResource L.Perf.LowGpuNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <CheckBox x:Name="ChkStaticThumbnails" Content="{DynamicResource L.Perf.StaticThumbs}" Checked="OnPerformanceChanged" Unchecked="OnPerformanceChanged"/>
                            <TextBlock Text="{DynamicResource L.Perf.StaticThumbsNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,8" TextWrapping="Wrap"/>
                            <CheckBox x:Name="ChkSuspendThumbsBackground" Content="{DynamicResource L.Perf.SuspendBg}" Checked="OnPerformanceChanged" Unchecked="OnPerformanceChanged"/>
                            <TextBlock Text="{DynamicResource L.Perf.SuspendBgNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,4" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Perf.CoreOverrides}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Perf.CoreOverridesNote}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <ListView x:Name="LvPerClientCores" Height="180"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="220" DisplayMemberBinding="{Binding Character}"/>
                                        <!-- The combo box is populated in code-behind but bound here -->
                                        <GridViewColumn Header="{DynamicResource L.Perf.ColInactiveCore}" Width="150">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="130" ItemsSource="{Binding AvailableCores}" SelectedItem="{Binding SelectedCore, Mode=TwoWay}" SelectionChanged="OnPerClientCoreChanged" Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 11. FPS LIMITER ══ -->
                <StackPanel x:Name="PanelFPSLimiter" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Fps.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Fps.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtRtssStatus" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <GroupBox Header="{DynamicResource L.Fps.Settings}">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowFps" Content="{DynamicResource L.Fps.ShowOverlay}"
                                      Checked="OnShowFpsChanged" Unchecked="OnShowFpsChanged" Margin="4,4,0,8" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Fps.BackgroundFps}"/>
                                <ComboBox x:Name="CmbFpsLimit" Width="100" SelectionChanged="OnFpsLimiterChanged">
                                    <ComboBoxItem Content="5" Tag="5"/>
                                    <ComboBoxItem Content="10" Tag="10"/>
                                    <ComboBoxItem Content="15" Tag="15"/>
                                    <ComboBoxItem Content="30" Tag="30"/>
                                    <ComboBoxItem Content="60" Tag="60"/>
                                </ComboBox>
                            </StackPanel>
                            <Button Content="{DynamicResource L.Fps.ApplyProfile}" Padding="10,5" Click="OnApplyRtssProfile"
                                    HorizontalAlignment="Left" Margin="0,8,0,0"
                                    Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                            <TextBlock Text="{DynamicResource L.Fps.ApplyNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="10.5"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Fps.ManualInstall}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Fps.ManualNote}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource L.Fps.TargetFolder}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="TxtRtssProfilePath" Text="{DynamicResource L.Fps.Detecting}" Foreground="LimeGreen" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="{DynamicResource L.Fps.CopyFile}" Padding="10,5" Click="OnCopyRtssProfile"
                                        HorizontalAlignment="Left"/>
                                <Button Content="{DynamicResource L.Fps.OpenFolder}" Padding="10,5" Click="OnOpenRtssFolder"
                                        HorizontalAlignment="Left" Margin="6,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource L.Fps.ManualNote2}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" Margin="0,6,0,0" TextWrapping="Wrap" FontSize="10.5"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 12. STATS OVERLAY ══ -->
                <StackPanel x:Name="PanelStatsOverlay" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Stats.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Stats.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <!-- Master ON/OFF — when off, no stat overlay windows are created and any
                         currently-open ones are closed. All per-character / per-metric settings below
                         are preserved. -->
                    <CheckBox x:Name="ChkStatsOverlayEnabled" Content="{DynamicResource L.Stats.Enable}"
                              Checked="OnStatsChanged" Unchecked="OnStatsChanged"
                              FontWeight="SemiBold" Margin="0,0,0,10"
                              ToolTip="{DynamicResource L.Tt.StatsMaster}"/>

                    <!-- Global Master Switches — default for characters with no explicit override -->
                    <GroupBox Header="{DynamicResource L.Stats.GlobalDefaults}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Stats.GlobalDefaultsNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <!-- Per-metric checkboxes: 4 columns by category -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- DPS -->
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="{DynamicResource L.Stats.CatDps}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="ChkGmDpsOut" Content="Out · Dmg/s Out"    Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmDpsIn"  Content="In · Dmg/s In"      Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTdi"    Content="TDI · Total Dmg In" Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTdo"    Content="TDO · Total Dmg Out" Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmIncludeNpc" Content="Include NPC" Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged" Margin="0,6,0,0"/>
                                </StackPanel>
                                <!-- Logi -->
                                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                    <TextBlock Text="{DynamicResource L.Stats.CatLogi}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="ChkGmArps" Content="ARPS · Armor Rep/s"          Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmSrps" Content="SRPS · Shield Rep/s"         Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmCtps" Content="CTPS · Cap Transf/s"         Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTaro" Content="TARO · T. Armor Rep Out"     Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTari" Content="TARI · T. Armor Rep In"      Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTsro" Content="TSRO · T. Shield Rep Out"    Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTsri" Content="TSRI · T. Shield Rep In"     Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                </StackPanel>
                                <!-- Mining -->
                                <StackPanel Grid.Column="2" Margin="0,0,6,0">
                                    <TextBlock Text="{DynamicResource L.Stats.CatMining}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="ChkGmOmpc" Content="OMPC · Ore Mined/Cycle" Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmOmph" Content="OMPH · Ore Mined/Hour"  Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmGmpc" Content="GMPC · Gas Mined/Cycle" Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmGmph" Content="GMPH · Gas Mined/Hour"  Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmImph" Content="IMPH · Ice Mined/Hour"  Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                </StackPanel>
                                <!-- Ratting -->
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="{DynamicResource L.Stats.CatRatting}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="ChkGmTipt" Content="TIPT · Total ISK/Tick"    Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTiph" Content="TIPH · Total ISK/Hour"    Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                    <CheckBox x:Name="ChkGmTips" Content="TIPS · Total ISK/Session" Checked="OnStatGlobalChanged" Unchecked="OnStatGlobalChanged"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <!-- Per-Character Stat Toggles -->
                    <GroupBox Header="{DynamicResource L.Stats.ActiveChars}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button x:Name="BtnRefreshStatChars" Content="{DynamicResource L.Common.RefreshBtn}" Padding="8,3" Click="OnRefreshStatCharacters"
                                        Background="#e0e0e0" Foreground="#1a1a2e"
                                        BorderBrush="{StaticResource BorderBrush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="{DynamicResource L.Stats.DoubleClickNote}" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="12,0,0,0"/>
                            </StackPanel>
                            <ListView x:Name="LvStatCharacters" MinHeight="60" MaxHeight="360"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      MouseDoubleClick="OnStatCharRowDoubleClick">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="180" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="{DynamicResource L.Stats.ColOverrides}" Width="280" DisplayMemberBinding="{Binding Summary}"/>
                                        <GridViewColumn Header="" Width="70">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{DynamicResource L.Common.EditWord}" Padding="10,2" Click="OnStatCharEditClick"
                                                            Background="#2a3347" Foreground="{StaticResource TextPrimaryBrush}"
                                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock Text="{DynamicResource L.Stats.NpcNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource L.Stats.Display}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Stats.FontSize}" Width="120"/>
                                <Slider x:Name="SliderStatFont" Minimum="6" Maximum="16" Width="150" ValueChanged="OnStatsChanged"/>
                                <TextBlock x:Name="TxtStatFontValue" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Stats.OverlayOpacity}" Width="120"/>
                                <Slider x:Name="SliderStatOpacity" Minimum="10" Maximum="255" Width="150" ValueChanged="OnStatsChanged"/>
                                <TextBlock x:Name="TxtStatOpacityValue" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Stats.BgColor}" Width="120"/>
                                <TextBox x:Name="TxtStatBgColor" Width="90" TextChanged="OnStatsChanged"/>
                                <Border x:Name="PreviewStatBg" Width="20" Height="20" CornerRadius="3"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="6,0,0,0"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtStatBgColor" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Stats.TextColor}" Width="120"/>
                                <TextBox x:Name="TxtStatTextColor" Width="90" TextChanged="OnStatsChanged"/>
                                <Border x:Name="PreviewStatText" Width="20" Height="20" CornerRadius="3"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="6,0,0,0"/>
                                <Button Content="🎨" Style="{StaticResource IconBtn}" Click="OnPickColor" Tag="TxtStatTextColor" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Stats.Logging}">
                        <StackPanel>
                            <CheckBox x:Name="ChkStatLogging" Content="{DynamicResource L.Stats.EnableLogging}" Checked="OnStatsChanged" Unchecked="OnStatsChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Stats.LogFolder}" Width="100"/>
                                <TextBox x:Name="TxtStatLogDir" Width="250" TextChanged="OnStatsChanged"/>
                                <Button Content="📁" Style="{StaticResource IconBtn}" Click="OnBrowseStatLog" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Label Content="{DynamicResource L.Stats.AutoDelete}" Width="120"/>
                                <TextBox x:Name="TxtStatLogRetention" Width="50" TextChanged="OnStatsChanged"/>
                                <Label Content="{DynamicResource L.Common.Days}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Acronym Legend -->
                    <GroupBox Header="{DynamicResource L.Stats.Legend}">
                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                   Text="DPS:                         Mine:&#x0A;Out=Dmg/s Out                OMPC=Ore Mined/Cycle&#x0A;In=Dmg/s In                  OMPH=Ore Mined/Hour&#x0A;TDI=Total Dmg In             GMPC=Gas Mined/Cycle&#x0A;TDO=Total Dmg Out            GMPH=Gas Mined/Hour&#x0A;                             IMPH=Ice Mined/Hour&#x0A;&#x0A;Logi:                        Rat:&#x0A;ARPS=Armor Rep/s             TIPT=Total ISK/Tick&#x0A;SRPS=Shield Rep/s            TIPH=Total ISK/Hour&#x0A;CTPS=Cap Transf/s            TIPS=Total ISK/Session&#x0A;TARO=Total Armor Rep Out&#x0A;TARI=Total Armor Rep In&#x0A;TSRO=Total Shield Rep Out&#x0A;TSRI=Total Shield Rep In"/>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 13. EVE MANAGER ══ -->
                <StackPanel x:Name="PanelEVEManager" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Eve.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Eve.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <!-- EVE Settings Folder -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource L.Eve.SettingsFolder}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Width="130"/>
                        <TextBox x:Name="TxtEveSettingsDir" Width="300" IsReadOnly="True" TextChanged="OnEveManagerDirChanged"/>
                        <Button Content="{DynamicResource L.Common.Browse}" Padding="8,3" Click="OnBrowseEveDir" Margin="4,0,0,0"
                                Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"/>
                        <Button Content="🔄" Padding="6,3" Click="OnAutoDetectEveDir" Margin="4,0,0,0"
                                Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.AutoDetectEve}"/>
                    </StackPanel>

                    <!-- Mode Toggle Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnProfileCopyMode" Content="{DynamicResource L.Eve.ProfileCopyMode}" Padding="14,5" Click="OnEveMgrProfileMode"
                                Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                                FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <Button x:Name="BtnCharCopyMode" Content="{DynamicResource L.Eve.CharCopyMode}" Padding="14,5" Click="OnEveMgrCharMode"
                                Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                                FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <Button x:Name="BtnAccountCopyMode" Content="{DynamicResource L.Eve.AccountCopyMode}" Padding="14,5" Click="OnEveMgrAccountMode"
                                Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"
                                FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- ── PROFILE COPY GROUP (shown by default) ── -->
                    <StackPanel x:Name="EveMgrProfileGroup">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource L.Eve.SourceProfile}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource L.Eve.TargetProfiles}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                            <ListView x:Name="LvEveMgrSource" Grid.Row="1" Grid.Column="0" Height="220"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Eve.ColProfile}" Width="170">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource L.Eve.ColAccounts}" Width="65" DisplayMemberBinding="{Binding CharCount}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <ListView x:Name="LvEveMgrTarget" Grid.Row="1" Grid.Column="2" Height="220"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Eve.ColProfile}" Width="170">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource L.Eve.ColAccounts}" Width="65" DisplayMemberBinding="{Binding CharCount}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="{DynamicResource L.Eve.RefreshList}" Padding="10,5" Click="OnRefreshProfiles"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource L.Eve.BackupChecked}" Padding="10,5" Click="OnBackupCheckedTargets"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource L.Eve.CopyToChecked}" Padding="10,5" Click="OnCopyToCheckedTargets"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── CHAR COPY GROUP (initially hidden) ── -->
                    <StackPanel x:Name="EveMgrCharGroup" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource L.Eve.SourceShort}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource L.Eve.TargetShort}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource L.Eve.ProfileLabel}" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbCharSrcProfile" Width="200" SelectionChanged="OnCharSrcProfileChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource L.Eve.ProfileLabel}" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbCharTgtProfile" Width="200" SelectionChanged="OnCharTgtProfileChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                            </StackPanel>
                            <TextBox x:Name="TxtCharSrcSearch" Grid.Row="2" Grid.Column="0"
                                     TextChanged="OnCharSrcSearchChanged" Margin="0,0,0,4"
                                     Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" Padding="4,3"
                                     Tag="{DynamicResource L.Eve.SearchChars}"/>
                            <TextBox x:Name="TxtCharTgtSearch" Grid.Row="2" Grid.Column="2"
                                     TextChanged="OnCharTgtSearchChanged" Margin="0,0,0,4"
                                     Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" Padding="4,3"
                                     Tag="{DynamicResource L.Eve.SearchChars}"/>
                            <ListView x:Name="LvCharSrcChars" Grid.Row="3" Grid.Column="0" Height="230"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="160">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource L.Common.Id}" Width="85" DisplayMemberBinding="{Binding Id}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <ListView x:Name="LvCharTgtChars" Grid.Row="3" Grid.Column="2" Height="230"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Common.Character}" Width="160">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource L.Common.Id}" Width="85" DisplayMemberBinding="{Binding Id}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <CheckBox x:Name="ChkCopyAllChars" Grid.Row="4" Grid.Column="0"
                                      Content="{DynamicResource L.Eve.CopyAllChars}" Margin="0,6,0,0"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Grid.Row="4" Grid.Column="2" Content="{DynamicResource L.Eve.CopyCharSettings}" Padding="10,5"
                                    Click="OnCharCopyExecute" HorizontalAlignment="Right" Margin="0,6,0,0"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── ACCOUNT COPY GROUP (initially hidden) ── -->
                    <StackPanel x:Name="EveMgrAccountGroup" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource L.Eve.AccountNote}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource L.Eve.SourceShort}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource L.Eve.TargetShort}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource L.Eve.ProfileLabel}" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbAcctSrcProfile" Width="200" SelectionChanged="OnAcctSrcProfileChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource L.Eve.ProfileLabel}" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbAcctTgtProfile" Width="200" SelectionChanged="OnAcctTgtProfileChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                            </StackPanel>
                            <TextBox x:Name="TxtAcctSrcSearch" Grid.Row="2" Grid.Column="0"
                                     TextChanged="OnAcctSrcSearchChanged" Margin="0,0,0,4"
                                     Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" Padding="4,3"
                                     Tag="{DynamicResource L.Eve.SearchAccounts}"/>
                            <TextBox x:Name="TxtAcctTgtSearch" Grid.Row="2" Grid.Column="2"
                                     TextChanged="OnAcctTgtSearchChanged" Margin="0,0,0,4"
                                     Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" Padding="4,3"
                                     Tag="{DynamicResource L.Eve.SearchAccounts}"/>
                            <ListView x:Name="LvAcctSrcAccounts" Grid.Row="3" Grid.Column="0" Height="230"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Eve.ColAccount}" Width="160">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource L.Common.Id}" Width="85" DisplayMemberBinding="{Binding Id}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <ListView x:Name="LvAcctTgtAccounts" Grid.Row="3" Grid.Column="2" Height="230"
                                      Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}" FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{DynamicResource L.Eve.ColAccount}" Width="160">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{DynamicResource L.Common.Id}" Width="85" DisplayMemberBinding="{Binding Id}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <CheckBox x:Name="ChkCopyAllAccounts" Grid.Row="4" Grid.Column="0"
                                      Content="{DynamicResource L.Eve.CopyAllAccounts}" Margin="0,6,0,0"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Grid.Row="4" Grid.Column="2" Content="{DynamicResource L.Eve.CopyAcctSettings}" Padding="10,5"
                                    Click="OnAcctCopyExecute" HorizontalAlignment="Right" Margin="0,6,0,0"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" FontWeight="SemiBold"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="{DynamicResource L.Eve.DetectAccount}" Padding="10,4" Click="OnAcctDetectWizard"
                                    Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"
                                    FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource L.Eve.NameAccount}" Foreground="#888888"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="TxtAcctLabel" Width="160" Padding="4,3"
                                     Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"/>
                            <Button Content="{DynamicResource L.Eve.SetLabel}" Padding="10,4" Click="OnAcctSetLabel" Margin="6,0,0,0"
                                    Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource L.Eve.DetectNote}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- ── SHARED BOTTOM SECTION ── -->
                    <TextBlock x:Name="TxtEveMgrStatus" Text="{DynamicResource L.Common.Ready}" Foreground="#888888" FontSize="11" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{DynamicResource L.Eve.BackupLocation}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Width="120"/>
                        <TextBox x:Name="TxtEveBackupDir" Width="300" IsReadOnly="True" TextChanged="OnEveManagerDirChanged"/>
                        <Button Content="{DynamicResource L.Common.Browse}" Padding="8,3" Click="OnBrowseBackupDir" Margin="4,0,0,0"
                                Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"/>
                        <Button Content="🔄" Padding="6,3" Click="OnResetBackupDir" Margin="4,0,0,0"
                                Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc" ToolTip="{DynamicResource L.Tt.ResetDefault}"/>
                    </StackPanel>
                    <Button Content="{DynamicResource L.Eve.FetchEsi}" Padding="10,5"
                            Click="OnFetchESI" HorizontalAlignment="Left" Margin="0,4,0,8"
                            Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"/>
                    <TextBlock x:Name="TxtCharNameStatus" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" Margin="0,0,0,8"/>
                    <GroupBox Header="{DynamicResource L.Eve.DataMgmt}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource L.Eve.CopyProfileOther}" Padding="10,5" Click="OnCopyLayout"
                                    Background="#e0e0e0" Foreground="#1a1a2e"
                                    BorderBrush="#cccccc" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource L.Eve.ExportSettings}" Padding="10,5" Click="OnExportSettings"
                                    Background="#e0e0e0" Foreground="#1a1a2e"
                                    BorderBrush="#cccccc" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource L.Eve.ImportSettings}" Padding="10,5" Click="OnImportSettings"
                                    Background="#e0e0e0" Foreground="#1a1a2e"
                                    BorderBrush="#cccccc"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ 14. ABOUT ══ -->
                <StackPanel x:Name="PanelAbout" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.About.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtAppVersion" Text="EVE MultiPreview vX.X.X" FontSize="16" Loaded="OnAboutLoaded"/>
                    <TextBlock Text="{DynamicResource L.About.Edition}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,8"/>
                    <TextBlock TextWrapping="Wrap"
                               Text="{DynamicResource L.About.Desc}"/>
                    <TextBlock Margin="0,12,0,0" Text="{DynamicResource L.About.Origin}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Margin="0,4,0,0" Text="{DynamicResource L.About.Ported}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="{DynamicResource L.About.GitHub}" Padding="10,5" Click="OnOpenGitHub"
                                Background="#e0e0e0" Foreground="#1a1a2e"
                                BorderBrush="#cccccc"/>
                        <Button x:Name="BtnCheckVersion" Content="{DynamicResource L.About.CheckUpdates}" Padding="10,5" Margin="8,0,0,0"
                                Click="OnCheckVersion"
                                Background="#e0e0e0" Foreground="#1a1a2e"
                                BorderBrush="#cccccc"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkCheckUpdatesOnStartup" Content="{DynamicResource L.About.CheckOnStartup}" Margin="0,8,0,0"
                              Checked="OnCheckUpdatesOnStartupChanged" Unchecked="OnCheckUpdatesOnStartupChanged" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="ChkPreReleaseUpdates" Content="{DynamicResource L.About.PreRelease}" Margin="0,8,0,0"
                              Checked="OnPreReleaseChanged" Unchecked="OnPreReleaseChanged" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="TxtVersionResult" Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Margin="0,16,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic"
                               Text="{DynamicResource L.About.PreReleaseNote}"/>
                </StackPanel>

                <!-- ══ 15. DEBUG ══ -->
                <StackPanel x:Name="PanelDebug" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Debug.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Debug.Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <GroupBox Header="{DynamicResource L.Debug.Targets}">
                        <StackPanel>
                            <CheckBox x:Name="ChkDebugInjection" Content="{DynamicResource L.Debug.Injection}"
                                      Checked="OnDebugChanged" Unchecked="OnDebugChanged"/>
                            <CheckBox x:Name="ChkDebugCycling" Content="{DynamicResource L.Debug.Cycling}"
                                      Checked="OnDebugChanged" Unchecked="OnDebugChanged"/>
                            <CheckBox x:Name="ChkDebugWindowHooks" Content="{DynamicResource L.Debug.WindowHooks}"
                                      Checked="OnDebugChanged" Unchecked="OnDebugChanged"/>
                            <CheckBox x:Name="ChkDebugDwm" Content="{DynamicResource L.Debug.Dwm}"
                                      Checked="OnDebugChanged" Unchecked="OnDebugChanged"/>
                            <CheckBox x:Name="ChkDebugAlerts" Content="{DynamicResource L.Debug.Alerts}"
                                      Checked="OnDebugChanged" Unchecked="OnDebugChanged"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource L.Debug.LogMgmt}">
                        <StackPanel>
                            <Button Content="{DynamicResource L.Debug.OpenLogs}" Padding="10,6" HorizontalAlignment="Left" Click="OnOpenLogsFolder"
                                    Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                            <TextBlock Text="{DynamicResource L.Debug.LogsNote}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- ══ CROP ══ -->
                <StackPanel x:Name="PanelCrop" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L.Crop.Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L.Crop.Subtitle}"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <GroupBox Header="{DynamicResource L.Sounds.Master}">
                        <StackPanel>
                            <CheckBox x:Name="ChkCropEnabled" Content="{DynamicResource L.Crop.Enable}"
                                      Checked="OnCropEnabledChanged" Unchecked="OnCropEnabledChanged"/>
                            <TextBlock Text="{DynamicResource L.Crop.EnableNote}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="24,0,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource L.Crop.CropsHeader}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Label Content="{DynamicResource L.Layout.Character}" Width="80" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CmbCropCharacter" Width="220"
                                          SelectionChanged="OnCropCharacterChanged"
                                          Background="{StaticResource BgPanelBrush}" Foreground="White"/>
                                <Button Content="{DynamicResource L.Common.RefreshBtn}" Margin="6,0,0,0" Padding="8,3"
                                        Click="OnRefreshCropCharacters"
                                        ToolTip="{DynamicResource L.Tt.RescanCrop}"
                                        Background="#e0e0e0" Foreground="#1a1a2e" BorderBrush="#cccccc"/>
                                <Button Content="{DynamicResource L.Crop.AddCrop}" Margin="12,0,0,0" Padding="10,3"
                                        Click="OnAddCrop"
                                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                            <StackPanel x:Name="CropListPanel"/>
                            <TextBlock x:Name="CropEmptyHint"
                                       Text="{DynamicResource L.Crop.EmptyHint}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- ═══ Right Splitter ═══ -->
        <GridSplitter x:Name="WikiSplitter" Grid.Row="1" Grid.Column="3" Width="4"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="#FF1a1a3e" Cursor="SizeWE" Visibility="Collapsed"/>

        <!-- ═══ Help/Wiki Sidebar ═══ -->
        <Border x:Name="WikiPanel" Grid.Row="1" Grid.Column="4" Background="#FF141425" Padding="12,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource L.Help.Title}" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="WikiContent" TextWrapping="Wrap" FontSize="11.5"
                               FontFamily="Segoe UI" Foreground="#c0c8d8"
                               LineHeight="17"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
