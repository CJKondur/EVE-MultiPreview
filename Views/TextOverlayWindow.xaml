<Window x:Class="EveMultiPreview.Views.TextOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        AllowsTransparency="True"
        Background="Transparent"
        Title="TextOverlay">

    <Grid x:Name="OverlayRoot">
        <!-- Cycle-exclusion indicator (issue #16 / #27 / #40) — small badge in
             the top-LEFT corner, mirroring the alert-count badge in the top
             right. Replaces the earlier corner-to-corner red X strikeout,
             which obscured the thumbnail content. Visibility is toggled by
             SetCycleExcluded. -->
        <Border x:Name="ExclusionBadge"
                Width="20" Height="20"
                CornerRadius="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="4,4,0,0"
                Background="#FFCC0000"
                BorderBrush="White"
                BorderThickness="1"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
            </Border.Effect>
            <TextBlock Text="✕"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <StackPanel x:Name="TextOverlayPanel"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Margin="5,5,5,0">
            
            <!-- Character name -->
            <TextBlock x:Name="NameOverlay"
                       Foreground="#FFfac57a"
                       FontSize="12"
                       FontFamily="Gill Sans MT"
                       FontWeight="Medium"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Annotation label (user-defined: "Scout", "DPS", "Logi", etc.) -->
            <TextBlock x:Name="AnnotationOverlay"
                       Foreground="#FF8ecfff"
                       FontSize="9"
                       FontFamily="Gill Sans MT"
                       FontWeight="Normal"
                       FontStyle="Italic"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- System name -->
            <TextBlock x:Name="SystemOverlay"
                       Foreground="#FFfac57a"
                       FontSize="10"
                       FontFamily="Gill Sans MT"
                       FontWeight="Normal"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Session timer -->
            <TextBlock x:Name="TimerOverlay"
                       Foreground="#FFfac57a"
                       FontSize="10"
                       FontFamily="Gill Sans MT"
                       FontWeight="Normal"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Process stats (CPU/RAM/VRAM) — Viewbox auto-shrinks text to fit thumbnail width -->
            <Viewbox x:Name="ProcessStatsViewbox"
                     Stretch="Uniform"
                     StretchDirection="DownOnly"
                     HorizontalAlignment="Left"
                     Visibility="Collapsed">
                <TextBlock x:Name="ProcessStatsOverlay"
                           Foreground="#FF90ee90"
                           FontSize="9"
                           FontFamily="Consolas"
                           FontWeight="Normal">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Viewbox>
        </StackPanel>

        <!-- FPS Overlay -->
        <TextBlock x:Name="FpsOverlay"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,5,5,0"
                   Foreground="#FFfac57a"
                   FontSize="12"
                   FontFamily="Gill Sans MT"
                   FontWeight="Medium"
                   Visibility="Collapsed">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Per-character unread alert badge (matches AlertHub badge styling).
             Severity-coloured circle with white count, painted top-right and
             rendered AFTER FpsOverlay so it draws on top when both are visible.
             Cleared the moment the user activates the client. -->
        <Border x:Name="AlertBadge"
                Width="20" Height="20"
                CornerRadius="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,4,0"
                Background="#FFCC0000"
                BorderBrush="White"
                BorderThickness="1"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
            </Border.Effect>
            <TextBlock x:Name="AlertBadgeText"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
