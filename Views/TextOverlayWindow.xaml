<Window x:Class="EveMultiPreview.Views.TextOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        AllowsTransparency="True"
        Background="Transparent"
        Title="TextOverlay">

    <Grid x:Name="OverlayRoot">
        <!-- Cycle-exclusion strikeout (issue #16 / #27) — drawn here in the WPF
             overlay (which sits ON TOP of the DWM thumbnail) instead of the
             underlying WinForms client area, where DWM composition would hide
             it. Visibility is toggled by SetCycleExcluded; lines stretch to the
             window's full size via SizeChanged. -->
        <Canvas x:Name="ExclusionStrikeout" IsHitTestVisible="False" Visibility="Collapsed">
            <Line x:Name="ExclusionLineA" X1="0" Y1="0"
                  Stroke="#FFDC0000" StrokeThickness="4"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Opacity="0.85"/>
            <Line x:Name="ExclusionLineB" X1="0"
                  Stroke="#FFDC0000" StrokeThickness="4"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Opacity="0.85"/>
        </Canvas>

        <StackPanel x:Name="TextOverlayPanel"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Margin="5,5,5,0">
            
            <!-- Character name -->
            <TextBlock x:Name="NameOverlay"
                       Foreground="#FFfac57a"
                       FontSize="12"
                       FontFamily="Gill Sans MT"
                       FontWeight="Medium"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Annotation label (user-defined: "Scout", "DPS", "Logi", etc.) -->
            <TextBlock x:Name="AnnotationOverlay"
                       Foreground="#FF8ecfff"
                       FontSize="9"
                       FontFamily="Gill Sans MT"
                       FontWeight="Normal"
                       FontStyle="Italic"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- System name -->
            <TextBlock x:Name="SystemOverlay"
                       Foreground="#FFfac57a"
                       FontSize="10"
                       FontFamily="Gill Sans MT"
                       FontWeight="Normal"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Session timer -->
            <TextBlock x:Name="TimerOverlay"
                       Foreground="#FFfac57a"
                       FontSize="10"
                       FontFamily="Gill Sans MT"
                       FontWeight="Normal"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Process stats (CPU/RAM/VRAM) — Viewbox auto-shrinks text to fit thumbnail width -->
            <Viewbox x:Name="ProcessStatsViewbox"
                     Stretch="Uniform"
                     StretchDirection="DownOnly"
                     HorizontalAlignment="Left"
                     Visibility="Collapsed">
                <TextBlock x:Name="ProcessStatsOverlay"
                           Foreground="#FF90ee90"
                           FontSize="9"
                           FontFamily="Consolas"
                           FontWeight="Normal">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Viewbox>
        </StackPanel>

        <!-- FPS Overlay -->
        <TextBlock x:Name="FpsOverlay"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,5,5,0"
                   Foreground="#FFfac57a"
                   FontSize="12"
                   FontFamily="Gill Sans MT"
                   FontWeight="Medium"
                   Visibility="Collapsed">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.9" Color="Black"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>
