<Window x:Class="EveMultiPreview.Views.ThumbnailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        SizeChanged="Window_SizeChanged"
        Title="EVE Thumbnail">

    <!-- 
        Borderless, transparent, always-on-top window.
        DWM thumbnail is painted directly onto the HWND surface by Windows.
        WPF content layer sits on top for overlays (text, borders).
        Matches AHK ThumbWindow.ahk architecture with separate overlay layers.
    -->
    <Grid x:Name="RootGrid">
        <!-- Background panel (visible when no thumbnail displayed) -->
        <Border x:Name="BackgroundPanel"
                Background="#01000000"
                BorderThickness="0"
                IsHitTestVisible="False"/>

        <!-- Border overlay (colored frame around the thumbnail — uses region clipping in code-behind) -->
        <Border x:Name="BorderOverlay"
                BorderBrush="Transparent"
                BorderThickness="0"
                IsHitTestVisible="False"/>

        <!-- Text overlays are rendered in separate TextOverlayWindow (DWM thumbnails occlude WPF content) -->

        <!-- Not-logged-in indicator overlay -->
        <Border x:Name="NotLoggedInOverlay"
                Background="#80000000"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock Text="Not Logged In"
                       Foreground="White"
                       FontSize="10"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
