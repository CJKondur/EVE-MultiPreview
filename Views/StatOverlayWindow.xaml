<Window x:Class="EveMultiPreview.Views.StatOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        Width="280"
        Height="120"
        Title="Stat Overlay">
    
    <!-- AHK parity: dark background (#1a1a2e), Consolas monospace for aligned columns -->
    <Border x:Name="RootBorder"
            Background="#D01a1a2e"
            BorderBrush="#FF4080AA"
            BorderThickness="1"
            CornerRadius="4"
            Padding="6,3">
        <StackPanel>
            <!-- Character name header (AHK: Segoe UI 9pt w700 #FAC57A) -->
            <TextBlock x:Name="CharNameLabel"
                       FontSize="9"
                       FontFamily="Segoe UI"
                       Foreground="#FFFAC57A"
                       FontWeight="Bold"/>
            
            <!-- Multi-column stat text (AHK: Consolas 8pt w600 #00FF88) -->
            <TextBlock x:Name="StatLabel"
                       FontSize="8"
                       FontFamily="Consolas"
                       FontWeight="SemiBold"
                       Foreground="#FF00FF88">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="2" Opacity="0.4" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- Hidden by default — only shown for legacy single-value mode -->
            <TextBlock x:Name="StatUnit"
                       FontSize="8"
                       FontFamily="Consolas"
                       Foreground="#888888"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>
